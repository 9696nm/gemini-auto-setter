{
  "manifest_version": 3,
  "name": "Gemini Auto Setter",
  "version": "1.0.0",
  "description": "Geminiを開いた際に一時チャットと指定モードを自動適用する",
  "permissions": ["storage"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_title": "設定を開く"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
